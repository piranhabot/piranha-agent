# Piranha Agent - Environment Configuration
# Copy this file to .env and update values for production

# =============================================================================
# Security Configuration
# =============================================================================

# Secret key for JWT token generation
# IMPORTANT: Change this to a strong random string in production!
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# JWT token expiration in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins for CORS (comma-separated)
# IMPORTANT: Restrict to your actual domains in production!
# Example: ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# =============================================================================
# Rate Limiting
# =============================================================================

# Maximum requests per minute per IP
# Lower this for production (recommended: 30-60)
RATE_LIMIT_PER_MINUTE=60

# =============================================================================
# API Keys (Optional)
# =============================================================================

# Comma-separated list of valid API keys
# Leave empty to disable API key authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Example: API_KEYS=key1,key2,key3
API_KEYS=

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection string (for production event store)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/piranha

# Use in-memory SQLite (for development/testing)
# Set to "true" to use in-memory instead of PostgreSQL
USE_IN_MEMORY_DB=false

# =============================================================================
# LLM Configuration
# =============================================================================

# Ollama API base URL
OLLAMA_API_BASE=http://localhost:11434

# Default LLM model
DEFAULT_MODEL=ollama/llama3:latest

# =============================================================================
# API Keys for LLM Providers (Optional)
# =============================================================================

# Anthropic API key (for Claude)
ANTHROPIC_API_KEY=

# OpenAI API key
OPENAI_API_KEY=

# Hugging Face API key
HUGGINGFACE_API_KEY=

# OpenRouter API key
OPENROUTER_API_KEY=

# =============================================================================
# Monitoring & Logging
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable/disable request logging
REQUEST_LOGGING=true

# =============================================================================
# Performance Configuration
# =============================================================================

# Maximum number of WebSocket connections
MAX_WEBSOCKET_CONNECTIONS=100

# WebSocket heartbeat interval in seconds
WEBSOCKET_HEARTBEAT_INTERVAL=30

# Cache TTL in hours
CACHE_TTL_HOURS=24

# Maximum cache entries
CACHE_MAX_ENTRIES=10000

# =============================================================================
# Production Settings
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Enable/disable debug mode
DEBUG=true

# Server host
HOST=0.0.0.0

# Server port
PORT=8080

# =============================================================================
# Security Checklist for Production
# =============================================================================
# Before deploying to production, ensure:
# [ ] SECRET_KEY is set to a strong random value
# [ ] ALLOWED_ORIGINS is restricted to your domains
# [ ] RATE_LIMIT_PER_MINUTE is set appropriately (30-60)
# [ ] API_KEYS are configured if using API authentication
# [ ] DEBUG is set to false
# [ ] ENVIRONMENT is set to "production"
# [ ] Database credentials are secure
# [ ] LLM API keys are set if using cloud providers
# [ ] Log level is set to INFO or WARNING
# =============================================================================
