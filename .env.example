# Piranha Agent - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# Security (REQUIRED for production)
# =============================================================================

# Generate a strong secret key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-min-32-characters-long

# JWT token expiration
ACCESS_TOKEN_EXPIRE_MINUTES=60

# =============================================================================
# API Configuration
# =============================================================================

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# API keys for authentication (comma-separated)
API_KEYS=

# =============================================================================
# Database (Optional - defaults to SQLite)
# =============================================================================

# PostgreSQL connection string (for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/piranha

# =============================================================================
# LLM Providers (Optional - set as needed)
# =============================================================================

# OpenAI
# OPENAI_API_KEY=sk-...

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Google
# GOOGLE_API_KEY=...

# HuggingFace
# HUGGINGFACE_API_KEY=...

# =============================================================================
# Monitoring (Optional)
# =============================================================================

# Ollama (local LLM)
# OLLAMA_HOST=localhost:11434

# =============================================================================
# Claude Code Explorer (Optional)
# =============================================================================

# Path to Claude Code source root (for MCP server)
# CLAUDE_CODE_SRC_ROOT=../src

# MCP server connection timeout in seconds
# CLAUDE_CODE_MCP_TIMEOUT=30

# MCP server command (default: npx)
# CLAUDE_CODE_MCP_COMMAND=npx

# MCP server arguments (default: -y claude-code-explorer-mcp)
# CLAUDE_CODE_MCP_ARGS=-y,claude-code-explorer-mcp

# =============================================================================
# Development (Optional)
# =============================================================================

# Debug mode (set to False in production)
DEBUG=True

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO
